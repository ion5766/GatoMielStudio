{
  "version": 2,
  "builds": [
    {
      "src": "api/pagar.js",
      "use": "@vercel/node"
    },
    {
      "src": "api/notify.js",
      "use": "@vercel/node"
    },
    {
      "src": "api/test.js",
      "use": "@vercel/node"
    },
    {
      "src": "**/*.html",
      "use": "@vercel/static"
    },
    {
      "src": "**/*.css",
      "use": "@vercel/static"
    },
    {
      "src": "**/*",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/pagar",
      "dest": "/api/pagar.js"
    },
    {
      "src": "/api/notify",
      "dest": "/api/notify.js"
    },
    {
      "src": "/api/test",
      "dest": "/api/test.js"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ]
}
